{
  "name": "argus",
  "version": "0.1.0",
  "description": "AI-powered SOC analyst assistant and cybersecurity research platform with hybrid RAG, investigation workspace, and reproducible experiment baselines.",
  "license": "MIT",
  "private": true,
  "contributors": [
    {
      "name": "Zaid Ahmed Ansari",
      "url": "https://github.com/Zaid-Ahmed-Ansari",
      "img": "https://github.com/Zaid-Ahmed-Ansari.png",
      "info": ["Author & maintainer"]
    }
  ],
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:setup:prod": "prisma migrate deploy && npm run db:seed:knowledge && npm run db:embed",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:knowledge": "tsx prisma/seed-knowledge.ts",
    "db:embed": "tsx prisma/embed-chunks.ts",
    "experiment:run": "tsx scripts/run-experiment.ts",
    "experiment:all": "tsx scripts/run-experiment.ts --all-fixtures",
    "experiment:scenario": "tsx scripts/run-experiment.ts --fixture",
    "experiment:rag": "tsx scripts/run-experiment.ts exp-002",
    "experiment:baseline": "tsx scripts/export-research-baseline.ts",
    "research:extract-samples": "tsx scripts/extract-research-samples.ts",
    "research:build-aggregates": "tsx scripts/build-research-aggregates.ts",
    "research:validate": "tsx scripts/validate-research-data.ts",
    "research:prepare": "npm run research:extract-samples && npm run research:build-aggregates && npm run research:validate",
    "audit": "npm audit --omit=dev",
    "boneyard:build": "boneyard-js build http://localhost:3000/dev/bones",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "@uploadthing/react": "^7.3.3",
    "@xyflow/react": "^12.11.0",
    "better-auth": "^1.6.14",
    "boneyard-js": "^1.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "isomorphic-dompurify": "^3.3.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uploadthing": "^7.7.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "prisma": "^7.8.0",
    "shadcn": "^4.10.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
