# ── Local development ──────────────────────────────────────────────
# For local Postgres, set both URLs to the same connection string.
DATABASE_URL="postgresql://user:pass@localhost:5432/argus"
DIRECT_URL="postgresql://user:pass@localhost:5432/argus"
DATABASE_POOL_MAX=10
UPLOAD_DIR=storage

# UploadThing — required on Vercel (no persistent local disk)
# Get token from https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=

# Better Auth (required — see docs/supabase-setup.md for why not Supabase Auth)
BETTER_AUTH_SECRET="generate-a-random-32-char-minimum-secret"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Bump when you replace public/logo.png (busts logo/favicon cache)
NEXT_PUBLIC_LOGO_VERSION="1"

# AI providers
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
OPENAI_API_KEY=""
AI_DEFAULT_PROVIDER="gemini"
OPENAI_MODEL="gpt-4o-mini"
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"
RAG_RETRIEVER_MODE="hybrid"

# ── Supabase (production) ───────────────────────────────────────────
# DATABASE_URL → Transaction pooler, port 6543, append ?pgbouncer=true
# DIRECT_URL   → Session pooler, port 5432 (used by Prisma migrations)
# See docs/supabase-setup.md for step-by-step setup.
#
# BETTER_AUTH_URL / NEXT_PUBLIC_APP_URL → https://your-app.vercel.app
# UPLOADTHING_TOKEN → required on Vercel
# GEMINI_API_KEY    → required for analysis + embeddings
# Vercel runs `npm run vercel-build` (migrate deploy + next build)
